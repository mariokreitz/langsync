{
  "name": "@mariokreitz/langsync",
  "version": "0.5.0",
  "description": "Modern localization workflow tooling for TypeScript applications.",
  "keywords": [
    "i18n",
    "localization",
    "translation",
    "excel",
    "cli",
    "i18next",
    "ngx-translate",
    "react-intl",
    "ai-translation",
    "openai",
    "watch-mode"
  ],
  "license": "MIT",
  "author": "Mario Kreitz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mariokreitz/langsync.git",
    "directory": "packages/cli"
  },
  "homepage": "https://docs.langsync.kreitz-webdev.de",
  "bugs": {
    "url": "https://github.com/mariokreitz/langsync/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "langsync": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node ./dist/cli.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "chalk": "catalog:",
    "chokidar": "catalog:",
    "commander": "catalog:",
    "cosmiconfig": "catalog:",
    "cosmiconfig-typescript-loader": "^6.1.0",
    "exceljs": "catalog:",
    "listr2": "catalog:",
    "ora": "catalog:",
    "prompts": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@langsync/shared": "workspace:*",
    "@langsync/core": "workspace:*",
    "@langsync/excel-engine": "workspace:*",
    "@langsync/ai-engine": "workspace:*",
    "@types/prompts": "^2.4.9",
    "memfs": "^4.57.3"
  }
}
